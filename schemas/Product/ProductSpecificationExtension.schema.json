{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "#ProductSpecificationExtension",
  "title": "ProductSpecificationExtension",
  "description": "DOME extensions for TMForum Product Specification",
  "type": "object",
  "properties": {
    "cloudesireProductVersionId": {
      "type": "number",
      "description": "Cloudesire product version identifier"
    },
    "productSpecCharacteristic_ext": {
      "type": "array",
      "description": "Extended characteristic metadata for Cloudesire integration",
      "items": {
        "$ref": "#/definitions/ProductSpecCharacteristicExtension"
      }
    }
  },
  "definitions": {
    "ProductSpecCharacteristicExtension": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "cloudesireBillingItemId": {
          "type": "string",
          "description": "Cloudesire billing item identifier"
        },
        "cloudesireConfigurationParameterId": {
          "type": "string",
          "description": "Cloudesire configuration parameter identifier"
        },
        "productSpecCharacteristicValue": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProductSpecCharacteristicValueExtension"
          }
        }
      }
    },
    "ProductSpecCharacteristicValueExtension": {
      "type": "object",
      "properties": {
        "isDefault": {
          "type": "boolean"
        },
        "unitOfMeasure": {
          "type": "string"
        },
        "valueFrom": {
          "type": "number"
        },
        "valueTo": {
          "type": "number"
        },
        "value": {
          "type": ["string", "number", "boolean"]
        },
        "cloudesireBillingItemValueId": {
          "type": "string",
          "description": "Cloudesire billing item value identifier"
        }
      }
    }
  }
}
